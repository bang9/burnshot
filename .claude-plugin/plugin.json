{
  "name": "burnshot",
  "version": "v0.1.0",
  "description": "Proof-of-burn photo shots for AI coding sessions",
  "author": {
    "name": "bang9",
    "url": "https://github.com/bang9"
  },
  "repository": "https://github.com/bang9/burnshot",
  "license": "MIT",
  "keywords": ["tokens", "usage", "photo", "proof"],
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-binary.sh"
          }
        ]
      }
    ]
  }
}
